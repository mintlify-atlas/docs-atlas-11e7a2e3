  "keyFeatures": [
    "Apprentice (Aprendiz) management with search, create, edit, and delete",
    "Instructor management with role assignments",
    "Characterization record (Ficha de Caracterización) tracking tied to training programs and centers",
    "Logbook (Bitácora) upload and management via PDF files",
    "Training program and training center administration",
    "Regional and administrative role management",
    "Document type and EPS (health provider) catalog management",
    "Email notifications on apprentice record creation, update, and deletion",
    "Authentication with email/password login and session management",
    "Paginated search across all major modules"
  ],
  "publicApiSurface": [
    "GET /login — Show login form",
    "POST /login — Authenticate user",
    "POST /logout — Log out user",
    "GET /usuarios/create — Show user registration form",
    "POST /usuarios — Store new user",
    "GET /welcome — Dashboard (auth required)",
    "GET /aprendices — List apprentices with search",
    "POST /aprendices — Create apprentice",
    "GET /aprendices/{id} — View apprentice",
    "PUT /aprendices/{id} — Update apprentice",
    "DELETE /aprendices/{id} — Delete apprentice",
    "GET /bitacoras — List logbooks",
    "POST /bitacoras — Upload logbook PDF",
    "GET /fichasdecaracterizacion — List characterization records",
    "POST /fichasdecaracterizacion — Create characterization record",
    "GET /instructores — List instructors",
    "POST /instructores — Create instructor",
    "GET /programas — List training programs",
    "GET /centrosdeformacion — List training centers",
    "GET /regionales — List regionals",
    "GET /entecoformador — List co-training entities",
    "GET /eps — List EPS providers",
    "GET /rolesadministrativos — List administrative roles",
    "GET /tiposdocumentos — List document types"
  ]
}
